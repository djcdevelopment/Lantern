{
  "name": "lantern",
  "private": true,
  "version": "0.18.0",
  "type": "module",
  "description": "Lantern — GAD App / Workbench. Player-first local raid review and exploration.",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:web": "vite",
    "server": "node server/server.mjs",
    "build": "tsc -b && vite build",
    "prerender": "node scripts/prerender.mjs",
    "build:cloud": "node scripts/prerender.mjs && tsc -b && vite build --mode cloud",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit",
    "smoke": "node scripts/smoke.mjs"
  },
  "dependencies": {
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-router-dom": "6.30.1"
  },
  "devDependencies": {
    "@types/node": "^22.19.19",
    "@types/react": "18.3.12",
    "@types/react-dom": "18.3.1",
    "@vitejs/plugin-react": "4.3.4",
    "playwright-core": "^1.49.1",
    "typescript": "5.7.3",
    "vite": "6.0.7"
  }
}
